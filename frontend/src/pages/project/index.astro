---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CardProject from '../../components/CardProject.astro';
import { listPosts } from '../../lib/db';
import { getLayoutData } from '../../lib/layout-data';

const { env, profile, siteConfig } = await getLayoutData(Astro.locals);
const projectItems = await listPosts(env.DB, { type: 'project' });
---

<BaseLayout
  title="Project | Portfolio An Ninh Mạng"
  description="Các dự án tool/lab security với mô tả mục tiêu, stack và giới hạn."
  profile={profile}
  siteConfig={siteConfig}
>
  <section class="reveal">
    <h1 class="page-title">Projects</h1>
    <p class="page-description page-intro">
      Danh sách project ưu tiên tính thực tế: giải quyết vấn đề cụ thể, có hướng dẫn tái hiện và kết quả đo được.
    </p>
  </section>

  <section class="section">
    {projectItems.length > 0 ? (
      <div class="grid cols-2">
        {projectItems.map((item) => <CardProject item={item} siteConfig={siteConfig} />)}
      </div>
    ) : (
      <p class="empty-state glass-panel">Bạn chưa có project public nào ở thời điểm này.</p>
    )}
  </section>
</BaseLayout>
