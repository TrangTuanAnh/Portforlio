---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CardBlog from '../../components/CardBlog.astro';
import { listPosts } from '../../lib/db';
import { getLayoutData } from '../../lib/layout-data';

const { env, profile, siteConfig } = await getLayoutData(Astro.locals);
const blogItems = await listPosts(env.DB, { type: 'blog' });
---

<BaseLayout
  title="Blog | Portfolio An Ninh Mạng"
  description="Bài viết ngoài CTF: learning log, note và workflow kỹ thuật."
  profile={profile}
  siteConfig={siteConfig}
>
  <section class="reveal">
    <h1 class="page-title">Blog</h1>
    <p class="page-description page-intro">
      Không chỉ challenge CTF, đây là nơi mình ghi lại các quy trình học và tối ưu workflow thực hành bảo mật.
    </p>
  </section>

  <section class="section">
    {blogItems.length > 0 ? (
      <div class="grid cols-2">
        {blogItems.map((item) => <CardBlog item={item} siteConfig={siteConfig} />)}
      </div>
    ) : (
      <p class="empty-state glass-panel">Bạn chưa có bài blog public nào ở thời điểm này.</p>
    )}
  </section>
</BaseLayout>
