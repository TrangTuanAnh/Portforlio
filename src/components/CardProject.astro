---
import type { CollectionEntry } from 'astro:content';
import { entrySlug } from '../utils/content';

type ProjectEntry = CollectionEntry<'projects'>;

interface Props {
  item: ProjectEntry;
}

const { item } = Astro.props;
const slug = entrySlug(item);
const formattedDate = new Intl.DateTimeFormat('vi-VN', {
  day: '2-digit',
  month: '2-digit',
  year: 'numeric',
}).format(item.data.date);
---

<article class="card reveal glass-panel tilt-3d depth-hover" data-tilt-max="4.6">
  <div class="meta-list">
    <span class="meta">{formattedDate}</span>
  </div>
  <h3>
    <a href={`/project/${slug}`}>{item.data.title}</a>
  </h3>
  <p>{item.data.summary}</p>
  <div class="stack-list">
    {item.data.stack.map((stack) => (
      <span class="stack">{stack}</span>
    ))}
  </div>
  <a class="link-arrow" href={`/project/${slug}`}>Xem chi tiết →</a>
</article>
