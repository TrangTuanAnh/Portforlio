---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostLayout from '../../layouts/PostLayout.astro';
import { marked } from 'marked';
import { getPostBySlug } from '../../lib/db';
import { getLayoutData } from '../../lib/layout-data';
import type { CtfCategory } from '../../lib/models';

const { env, profile, siteConfig } = await getLayoutData(Astro.locals);
const slug = Astro.params.slug ?? '';
const post = await getPostBySlug(env.DB, 'ctf', slug);

if (post?.ctfExternalUrl) {
  return Astro.redirect(post.ctfExternalUrl);
}

if (!post) {
  Astro.response.status = 404;
}

const categoryLabelMap: Record<CtfCategory, string> = {
  web: 'Web',
  pwn: 'Pwn',
  reverse: 'Reverse',
  crypto: 'Cryptography',
  forensics: 'Forensics',
  osint: 'OSINT',
};
const labels = post
  ? [
      ...(post.ctfCategory ? [`Category: ${categoryLabelMap[post.ctfCategory]}`] : []),
      ...(post.ctfEvent ? [`Event: ${post.ctfEvent}`] : []),
      ...(post.ctfDifficulty ? [`Difficulty: ${post.ctfDifficulty}`] : []),
    ]
  : [];
const html = post ? await marked.parse(post.contentMarkdown || '') : '';
---

<BaseLayout
  title={post ? `${post.title} | CTF` : '404 | CTF'}
  description={post?.summary ?? 'Không tìm thấy bài CTF bạn yêu cầu.'}
  profile={profile}
  siteConfig={siteConfig}
>
  {post ? (
    <PostLayout title={post.title} description={post.summary} date={new Date(`${post.date}T00:00:00.000Z`)} labels={labels}>
      <Fragment set:html={html} />
    </PostLayout>
  ) : (
    <section class="hero reveal">
      <span class="hero-chip">404 Not Found</span>
      <h1>Bài CTF không tồn tại</h1>
      <p>Slug này chưa có nội dung public trong hệ thống CMS.</p>
      <div class="hero-cta">
        <a class="btn" href="/ctf">Quay lại CTF</a>
      </div>
    </section>
  )}
</BaseLayout>
