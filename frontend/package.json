{
  "name": "my-portfolio",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "db:migrate": "wrangler d1 migrations apply DB",
    "db:seed:generate": "node scripts/generate-d1-seed.mjs",
    "db:seed": "wrangler d1 execute DB --file migrations/0002_seed.sql",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "cf:bootstrap": "node scripts/cf-bootstrap.mjs"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.4",
    "astro": "^6.0.8",
    "bcryptjs": "^3.0.3",
    "gray-matter": "^4.0.3",
    "marked": "^17.0.5",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "wrangler": "^4.78.0"
  }
}
