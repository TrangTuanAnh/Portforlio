---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostLayout from '../../layouts/PostLayout.astro';
import { marked } from 'marked';
import { getPostBySlug } from '../../lib/db';
import { getLayoutData } from '../../lib/layout-data';

const { env, profile, siteConfig } = await getLayoutData(Astro.locals);
const slug = Astro.params.slug ?? '';
const post = await getPostBySlug(env.DB, 'project', slug);

if (!post) {
  Astro.response.status = 404;
}

const labels = post
  ? [...post.projectStack, ...(post.projectRepo ? ['Repo available'] : []), ...(post.projectDemo ? ['Demo available'] : [])]
  : [];
const html = post ? await marked.parse(post.contentMarkdown || '') : '';
---

<BaseLayout
  title={post ? `${post.title} | Project` : '404 | Project'}
  description={post?.summary ?? 'Không tìm thấy project bạn yêu cầu.'}
  profile={profile}
  siteConfig={siteConfig}
>
  {post ? (
    <PostLayout title={post.title} description={post.summary} date={new Date(`${post.date}T00:00:00.000Z`)} labels={labels}>
      <Fragment set:html={html} />

      {(post.projectRepo || post.projectDemo) && (
        <div class="meta-list" style="margin-top: 1.5rem;">
          {post.projectRepo && (
            <a class="btn" href={post.projectRepo} target="_blank" rel="noreferrer">
              Xem repository
            </a>
          )}
          {post.projectDemo && (
            <a class="btn" href={post.projectDemo} target="_blank" rel="noreferrer">
              Xem demo
            </a>
          )}
        </div>
      )}
    </PostLayout>
  ) : (
    <section class="hero reveal">
      <span class="hero-chip">404 Not Found</span>
      <h1>Project không tồn tại</h1>
      <p>Slug này chưa có nội dung public trong hệ thống CMS.</p>
      <div class="hero-cta">
        <a class="btn" href="/project">Quay lại Project</a>
      </div>
    </section>
  )}
</BaseLayout>
