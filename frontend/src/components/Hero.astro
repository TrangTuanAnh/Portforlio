---
import type { ProfileData, SiteConfig } from '../lib/models';

interface Props {
  profile: ProfileData;
  siteConfig: SiteConfig;
}

const { profile, siteConfig } = Astro.props;

const enable3d = siteConfig.ui.enable3dEffects;
const heroClass = enable3d ? 'hero reveal glass-panel tilt-3d depth-hover' : 'hero reveal glass-panel';
const heroTiltMax = siteConfig.ui.heroTiltMax;
---

<section class={heroClass} data-tilt-max={enable3d ? heroTiltMax : undefined}>
  <span class="hero-chip">CTF Writeup · Security Projects · Learning Log</span>
  <h1>{profile.name}</h1>
  <p>
    {profile.headline}. Mình chia sẻ quá trình học an ninh mạng một cách thực tế: từ cách phân tích
    challenge CTF đến xây công cụ nhỏ phục vụ phòng thủ và nghiên cứu.
  </p>
  <div class="hero-cta">
    <a class="btn" href={siteConfig.links.heroPrimary}>Xem CTF Writeup</a>
    <a class="btn" href={siteConfig.links.heroSecondary}>Khám phá Project</a>
    <a class="btn" href={siteConfig.links.heroContact || `mailto:${profile.email}`}>Liên hệ nhanh</a>
  </div>
  {enable3d && <div class="hero-3d-canvas" data-cyber-sphere aria-hidden="true"></div>}
  {enable3d && <div class="hero-3d-fallback" aria-hidden="true"></div>}
</section>
