---
import type { PostRecord, SiteConfig } from '../lib/models';

type ProjectEntry = PostRecord;

interface Props {
  item: ProjectEntry;
  siteConfig: SiteConfig;
}

const { item, siteConfig } = Astro.props;
const enable3d = siteConfig.ui.enable3dEffects;
const cardClass = enable3d ? 'card reveal glass-panel tilt-3d depth-hover' : 'card reveal glass-panel';
const cardTiltMax = siteConfig.ui.cardTiltMax;
const formattedDate = new Intl.DateTimeFormat('vi-VN', {
  day: '2-digit',
  month: '2-digit',
  year: 'numeric',
}).format(new Date(`${item.date}T00:00:00.000Z`));
---

<article class={cardClass} data-tilt-max={enable3d ? cardTiltMax : undefined}>
  <div class="meta-list">
    <span class="meta">{formattedDate}</span>
  </div>
  <h3>
    <a href={`/project/${item.slug}`}>{item.title}</a>
  </h3>
  <p>{item.summary}</p>
  <div class="stack-list">
    {item.projectStack.map((stack) => (
      <span class="stack">{stack}</span>
    ))}
  </div>
  <a class="link-arrow" href={`/project/${item.slug}`}>Xem chi tiết →</a>
</article>
