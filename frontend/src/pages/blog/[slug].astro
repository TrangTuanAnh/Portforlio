---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostLayout from '../../layouts/PostLayout.astro';
import { marked } from 'marked';
import { getPostBySlug } from '../../lib/db';
import { getLayoutData } from '../../lib/layout-data';

const { env, profile, siteConfig } = await getLayoutData(Astro.locals);
const slug = Astro.params.slug ?? '';
const post = await getPostBySlug(env.DB, 'blog', slug);

if (!post) {
  Astro.response.status = 404;
}

const labels = post ? post.tags.map((tag) => `#${tag}`) : [];
const html = post ? await marked.parse(post.contentMarkdown || '') : '';
---

<BaseLayout
  title={post ? `${post.title} | Blog` : '404 | Blog'}
  description={post?.summary ?? 'Không tìm thấy bài blog bạn yêu cầu.'}
  profile={profile}
  siteConfig={siteConfig}
>
  {post ? (
    <PostLayout title={post.title} description={post.summary} date={new Date(`${post.date}T00:00:00.000Z`)} labels={labels}>
      <Fragment set:html={html} />
    </PostLayout>
  ) : (
    <section class="hero reveal">
      <span class="hero-chip">404 Not Found</span>
      <h1>Bài blog không tồn tại</h1>
      <p>Slug này chưa có nội dung public trong hệ thống CMS.</p>
      <div class="hero-cta">
        <a class="btn" href="/blog">Quay lại Blog</a>
      </div>
    </section>
  )}
</BaseLayout>
