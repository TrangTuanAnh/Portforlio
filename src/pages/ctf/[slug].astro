---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostLayout from '../../layouts/PostLayout.astro';
import { entrySlug, publishedOnly, sortByDateDesc } from '../../utils/content';

export async function getStaticPaths() {
  const posts = sortByDateDesc(await getCollection('ctf', publishedOnly)).filter((post) => !post.data.externalUrl);
  return posts.map((post) => ({ params: { slug: entrySlug(post) }, props: { post } }));
}

interface Props {
  post: CollectionEntry<'ctf'>;
}

const { post } = Astro.props;
const { Content } = await render(post);
const labels = [
  `Category: ${post.data.category}`,
  `Event: ${post.data.event}`,
  ...(post.data.difficulty ? [`Difficulty: ${post.data.difficulty}`] : []),
];
---

<BaseLayout title={`${post.data.title} | CTF`} description={post.data.summary}>
  <PostLayout title={post.data.title} description={post.data.summary} date={post.data.date} labels={labels}>
    <Content />
  </PostLayout>
</BaseLayout>
