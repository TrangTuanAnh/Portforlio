---
import { PROFILE } from '../profile';
import { SITE_CONFIG } from '../siteConfig';

const enable3d = SITE_CONFIG.ui.enable3dEffects;
const heroClass = enable3d ? 'hero reveal glass-panel tilt-3d depth-hover' : 'hero reveal glass-panel';
const heroTiltMax = SITE_CONFIG.ui.heroTiltMax;
---

<section class={heroClass} data-tilt-max={enable3d ? heroTiltMax : undefined}>
  <span class="hero-chip">CTF Writeup · Security Projects · Learning Log</span>
  <h1>{PROFILE.name}</h1>
  <p>
    {PROFILE.headline}. Mình chia sẻ quá trình học an ninh mạng một cách thực tế: từ cách phân tích
    challenge CTF đến xây công cụ nhỏ phục vụ phòng thủ và nghiên cứu.
  </p>
  <div class="hero-cta">
    <a class="btn" href={SITE_CONFIG.links.heroPrimary}>Xem CTF Writeup</a>
    <a class="btn" href={SITE_CONFIG.links.heroSecondary}>Khám phá Project</a>
    <a class="btn" href={SITE_CONFIG.links.heroContact || `mailto:${PROFILE.email}`}>Liên hệ nhanh</a>
  </div>
</section>
