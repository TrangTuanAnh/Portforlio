---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLayoutData } from '../lib/layout-data';

const { profile, siteConfig } = await getLayoutData(Astro.locals);
const enable3d = siteConfig.ui.enable3dEffects;
const infoClass = enable3d ? 'info-card reveal glass-panel tilt-3d depth-hover' : 'info-card reveal glass-panel';
const infoTiltMax = siteConfig.ui.infoTiltMax;
---

<BaseLayout
  title="About | Portfolio An Ninh Mạng"
  description="Thông tin cá nhân, định hướng và năng lực chính."
  profile={profile}
  siteConfig={siteConfig}
>
  <section class="reveal">
    <h1 class="page-title">About</h1>
    <p class="page-description page-intro">{profile.aboutIntro}</p>
  </section>

  <section class="section info-grid">
    <article class={infoClass} data-tilt-max={enable3d ? infoTiltMax : undefined}>
      <h3>Thông tin nhanh</h3>
      <p>Tên hiển thị: {profile.name}</p>
      <p>Khu vực: {profile.location}</p>
      <p>Định hướng: {profile.orientation}</p>
      {profile.resumeUrl && (
        <a class="btn" href={profile.resumeUrl} target="_blank" rel="noreferrer" style="margin-top: 0.5rem;">
          Xem CV
        </a>
      )}
    </article>

    <article class={infoClass} data-tilt-max={enable3d ? infoTiltMax : undefined}>
      <h3>Focus area</h3>
      <ul>
        {profile.focusAreas.map((item) => <li>{item}</li>)}
      </ul>
    </article>

    <article class={infoClass} data-tilt-max={enable3d ? infoTiltMax : undefined}>
      <h3>Tech stack thường dùng</h3>
      <ul>
        {profile.techStack.map((item) => <li>{item}</li>)}
      </ul>
    </article>

    <article class={infoClass} data-tilt-max={enable3d ? infoTiltMax : undefined}>
      <h3>Mục tiêu 2026</h3>
      <ul>
        {profile.goals.map((item) => <li>{item}</li>)}
      </ul>
    </article>
  </section>
</BaseLayout>
