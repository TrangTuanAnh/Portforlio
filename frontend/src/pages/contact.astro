---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLayoutData } from '../lib/layout-data';

const { profile, siteConfig } = await getLayoutData(Astro.locals);
const enable3d = siteConfig.ui.enable3dEffects;
const infoClass = enable3d ? 'info-card reveal glass-panel tilt-3d depth-hover' : 'info-card reveal glass-panel';
const infoTiltMax = siteConfig.ui.infoTiltMax;
---

<BaseLayout
  title="Contact | Portfolio An Ninh Mạng"
  description="Các kênh liên hệ: Email, GitHub, LinkedIn."
  profile={profile}
  siteConfig={siteConfig}
>
  <section class="reveal">
    <h1 class="page-title">Contact</h1>
    <p class="page-description page-intro">
      V1 giữ đơn giản, không dùng backend form. Bạn có thể liên hệ trực tiếp qua email hoặc social profile bên dưới.
    </p>
  </section>

  <section class="section info-grid">
    <article class={infoClass} data-tilt-max={enable3d ? infoTiltMax : undefined}>
      <h3>Email</h3>
      <p>Phù hợp cho trao đổi công việc hoặc hợp tác kỹ thuật.</p>
      <a class="btn" href={`mailto:${profile.email}`}>{profile.email}</a>
    </article>

    <article class={infoClass} data-tilt-max={enable3d ? infoTiltMax : undefined}>
      <h3>GitHub</h3>
      <p>Xem source code project, lịch sử commit và thử nghiệm tooling.</p>
      <a class="btn" href={profile.github} target="_blank" rel="noreferrer">Mở GitHub</a>
    </article>

    <article class={infoClass} data-tilt-max={enable3d ? infoTiltMax : undefined}>
      <h3>LinkedIn</h3>
      <p>Kênh phù hợp cho networking chuyên nghiệp và cập nhật định hướng nghề nghiệp.</p>
      <a class="btn" href={profile.linkedin} target="_blank" rel="noreferrer">Mở LinkedIn</a>
    </article>

    {profile.resumeUrl && (
      <article class={infoClass} data-tilt-max={enable3d ? infoTiltMax : undefined}>
        <h3>CV / Resume</h3>
        <p>URL CV được quản lý qua Admin CMS.</p>
        <a class="btn" href={profile.resumeUrl} target="_blank" rel="noreferrer">
          Mở CV
        </a>
      </article>
    )}
  </section>
</BaseLayout>

