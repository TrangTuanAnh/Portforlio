---
import type { CollectionEntry } from 'astro:content';
import { entrySlug } from '../utils/content';
import { SITE_CONFIG } from '../siteConfig';

type BlogEntry = CollectionEntry<'blog'>;

interface Props {
  item: BlogEntry;
}

const { item } = Astro.props;
const slug = entrySlug(item);
const enable3d = SITE_CONFIG.ui.enable3dEffects;
const cardClass = enable3d ? 'card reveal glass-panel tilt-3d depth-hover' : 'card reveal glass-panel';
const cardTiltMax = SITE_CONFIG.ui.cardTiltMax;
const formattedDate = new Intl.DateTimeFormat('vi-VN', {
  day: '2-digit',
  month: '2-digit',
  year: 'numeric',
}).format(item.data.date);
---

<article class={cardClass} data-tilt-max={enable3d ? cardTiltMax : undefined}>
  <div class="meta-list">
    <span class="meta">{formattedDate}</span>
  </div>
  <h3>
    <a href={`/blog/${slug}`}>{item.data.title}</a>
  </h3>
  <p>{item.data.summary}</p>
  <div class="badge-list">
    {item.data.tags.map((tag) => (
      <span class="badge">#{tag}</span>
    ))}
  </div>
  <a class="link-arrow" href={`/blog/${slug}`}>Đọc bài →</a>
</article>
