---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CardCTF from '../../components/CardCTF.astro';
import { listPosts } from '../../lib/db';
import { getLayoutData } from '../../lib/layout-data';

const { env, profile, siteConfig } = await getLayoutData(Astro.locals);
const ctfItems = await listPosts(env.DB, { type: 'ctf' });
---

<BaseLayout
  title="CTF | Portfolio An Ninh Mạng"
  description="Tổng hợp writeup CTF theo hướng thực chiến, có metadata rõ ràng."
  profile={profile}
  siteConfig={siteConfig}
>
  <section class="reveal">
    <h1 class="page-title">CTF Writeup</h1>
    <p class="page-description page-intro">
      Danh sách writeup được sắp theo thời gian mới nhất. Bài nào có link ngoài sẽ mở thẳng tới nơi chứa full writeup.
    </p>
  </section>

  <section class="section">
    {ctfItems.length > 0 ? (
      <div class="grid cols-3">
        {ctfItems.map((item) => <CardCTF item={item} siteConfig={siteConfig} />)}
      </div>
    ) : (
      <p class="empty-state glass-panel">Bạn chưa có writeup nào. Hãy thêm file trong `src/content/ctf`.</p>
    )}
  </section>
</BaseLayout>
