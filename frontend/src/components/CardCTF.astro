---
import type { PostRecord, SiteConfig } from '../lib/models';

type CtfEntry = PostRecord;

interface Props {
  item: CtfEntry;
  siteConfig: SiteConfig;
}

const { item, siteConfig } = Astro.props;
const href = item.ctfExternalUrl ?? `/ctf/${item.slug}`;
const isExternal = Boolean(item.ctfExternalUrl);
const categoryLabelMap: Record<NonNullable<CtfEntry['ctfCategory']>, string> = {
  web: 'Web',
  pwn: 'Pwn',
  reverse: 'Reverse',
  crypto: 'Cryptography',
  forensics: 'Forensics',
  osint: 'OSINT',
};
const categoryLabel = item.ctfCategory ? categoryLabelMap[item.ctfCategory] : 'CTF';
const enable3d = siteConfig.ui.enable3dEffects;
const cardClass = enable3d ? 'card reveal glass-panel tilt-3d depth-hover' : 'card reveal glass-panel';
const cardTiltMax = siteConfig.ui.cardTiltMax;
const formattedDate = new Intl.DateTimeFormat('vi-VN', {
  day: '2-digit',
  month: '2-digit',
  year: 'numeric',
}).format(new Date(`${item.date}T00:00:00.000Z`));
---

<article class={cardClass} data-tilt-max={enable3d ? cardTiltMax : undefined}>
  <div class="meta-list">
    <span class="meta">{formattedDate}</span>
    <span class="badge">{categoryLabel}</span>
    {item.ctfEvent && <span class="meta">{item.ctfEvent}</span>}
  </div>
  <h3>
    <a href={href} target={isExternal ? '_blank' : undefined} rel={isExternal ? 'noreferrer' : undefined}>
      {item.title}
    </a>
  </h3>
  <p>{item.summary}</p>
  <div class="badge-list">
    {item.tags.map((tag) => (
      <span class="badge">#{tag}</span>
    ))}
  </div>
  <a class="link-arrow" href={href} target={isExternal ? '_blank' : undefined} rel={isExternal ? 'noreferrer' : undefined}>
    {isExternal ? 'Đọc full writeup ↗' : 'Xem chi tiết →'}
  </a>
</article>
